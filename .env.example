# Server port
PORT=3000

# Runtime environment: development or production
NODE_ENV=development

# Production frontend origin allowed by CORS
FRONTEND_URL=

# Supabase project URL
SUPABASE_URL=

# Supabase anon key, kept for compatibility with local tooling
SUPABASE_ANON_KEY=

# Supabase service-role key used by backend services
SUPABASE_SERVICE_KEY=

# Gemini API key for embeddings and generation
GEMINI_API_KEY=

# SerpAPI key for product search
SERPAPI_KEY=

# Upstash Redis REST connection
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Lazada credentials, kept for compatibility with existing deployments
LAZADA_APP_KEY=
LAZADA_APP_SECRET=
